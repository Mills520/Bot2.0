# ------------------------------------------------------------------
# Discord Ops Bot configuration
# Copy this file to `.env` and fill in the values. Never commit .env.
# ------------------------------------------------------------------

# REQUIRED — bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: your server's ID. If set, slash commands sync instantly to that
# server. If empty, commands sync globally (can take up to an hour to appear).
GUILD_ID=

# Optional: a role ID that may use admin commands in addition to anyone
# with the "Manage Server" permission.
ADMIN_ROLE_ID=

# Fallback destination channels (channel IDs). Each server can override
# these at runtime with /setchannel — these are only used when a server
# hasn't configured its own.
ALERT_CHANNEL_ID=
BUG_CHANNEL_ID=
SUGGESTIONS_CHANNEL_ID=
STEAM_CHANNEL_ID=

# Feature tuning
WEATHER_DEFAULT_LOCATION=17067
WEB_CHECK_INTERVAL_MINUTES=5
STEAM_CHECK_INTERVAL_MINUTES=15
SLOW_RESPONSE_MS=2000
MAX_SITES_PER_GUILD=25

# Storage / logging
# PostgreSQL connection string: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://opsbot:CHANGE_ME@localhost:5432/opsbot
LOG_FILE=data/logs/opsbot.log
LOG_LEVEL=INFO
